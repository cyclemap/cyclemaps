{
	"compilerOptions": {
		"target": "es2022",
		"module": "es2022",
		"rootDir": "src",
		"outDir": "build",
		"moduleResolution": "bundler",
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmitOnError": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"],
	}
}
